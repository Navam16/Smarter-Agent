# ╔══════════════════════════════════════════════════════════════════╗
# ║            TALENTAI — ENVIRONMENT VARIABLES                      ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Copy this file:   cp .env.example .env
# Fill in your keys below
# NEVER commit .env to GitHub

# ══════════════════════════════════════════════════
# SERVICE: Groq
# USED FOR: LLM (skill extraction + AI processing)
# GET KEY: https://console.groq.com  →  Free
# ══════════════════════════════════════════════════
GROQ_API_KEY=gsk_your_groq_key_here

# ══════════════════════════════════════════════════
# SERVICE: GitHub
# USED FOR: Developer candidate sourcing
# GET KEY: github.com/settings/tokens → New token
#          Select: read:user, user:email
# COST: Completely FREE
# WITHOUT KEY: 60 requests/hour (limited)
# WITH KEY:    5000 requests/hour (recommended)
# ══════════════════════════════════════════════════
GITHUB_TOKEN=ghp_your_github_token_here

# ══════════════════════════════════════════════════
# SERVICE: Serper.dev
# USED FOR: Google search → LinkedIn/web profiles
# GET KEY: https://serper.dev  →  2500 free searches
# COST: Free tier / $50/month paid
# OPTIONAL: App works without this (GitHub only)
# ══════════════════════════════════════════════════
SERPER_API_KEY=your_serper_key_here
